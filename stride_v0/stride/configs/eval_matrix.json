{
  "version": "9.1",
  "dataset": {
    "glyph": "data/benchmark.glyph",
    "num_chunks": 6104,
    "source": "enwik8 (100MB)"
  },
  "indexes": {
    "l0_primary": "data/benchmark.glyph.l0",
    "l0_extended": "data/indexes/benchmark_5M_df1.glyph.l0",
    "fingerprints_w40": "data/benchmark.glyph.fingerprints.bin",
    "fingerprints_w24": "data/benchmark.glyph.fingerprints_w24.bin",
    "hotspots": "data/benchmark.glyph.hotspots.bin",
    "headersketch": "data/benchmark.glyph.headersketch.bin"
  },
  "build_params": {
    "l0_index": {
      "q": 8,
      "w": 8,
      "df_min": 1,
      "df_max": 256,
      "block_size": 64
    },
    "fingerprints_w40": {
      "q": 8,
      "w": 40,
      "bloom_bits": 16384,
      "k": 11
    },
    "fingerprints_w24": {
      "q": 8,
      "w": 24,
      "bloom_bits": 16384,
      "k": 11
    },
    "hotspots": {
      "q": 8,
      "w": 40,
      "max_df": 4096
    },
    "headersketch": {
      "sketch_bytes": 4096,
      "q": 8
    }
  },
  "verify": {
    "fast_cap": 256,
    "fast_cap_switch": 4096,
    "fast_cap_big": 2048,
    "adaptive": true,
    "hs_reorder_min": 16
  },
  "eval": {
    "seeds": [
      1
    ],
    "lengths": [
      48,
      96,
      192,
      384
    ],
    "trials_smoke": 200,
    "trials_full": 2000,
    "miss_decomp_cap": 256
  },
  "modes": {
    "baseline": {
      "description": "L0 index only, no bloom filters",
      "flags": "--e2e-verify --skip-old"
    },
    "bloom_stack": {
      "description": "L0 + Bloom w40 + Hotspots",
      "flags": "--e2e-verify --skip-old --bloom {fingerprints_w40} --hotspots {hotspots}"
    },
    "full_stack": {
      "description": "L0 + Bloom w40 + w24 miss-path + Hotspots + HeaderSketch",
      "flags": "--e2e-verify --skip-old --bloom {fingerprints_w40} --bloom-miss {fingerprints_w24} --hotspots {hotspots} --headersketch {headersketch}"
    }
  }
}